{
  "name": "@drcmind/ohada-lib",
  "version": "1.0.1",
  "description": "A developer-friendly OHADA accounting library that transforms business events into type-safe journal entries, manages stock and expenses, and generates compliant financial reports",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && node build.js && npm run build:dts",
    "build:dts": "dts-bundle-generator --no-check -o dist/index.d.ts src/index.ts",
    "test": "vitest",
    "clean": "rimraf dist coverage",
    "format": "prettier --write \"src/**/*.{ts,js,json}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Drc-Mind/ohda-lib.git"
  },
  "keywords": [
    "Ohada"
  ],
  "author": "Aksanti bahiga Tacite",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Drc-Mind/ohda-lib/issues"
  },
  "homepage": "https://github.com/Drc-Mind/ohda-lib#readme",
  "devDependencies": {
    "@types/node": "25.2.0",
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.27.3",
    "prettier": "3.8.1",
    "rimraf": "6.1.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "decimal.js": "10.6.0",
    "zod": "4.3.6"
  }
}
